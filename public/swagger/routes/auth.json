{
  "/v1/auth/sign-up": {
    "post": {
      "tags": ["Auth"],
      "summary": "Create New User",
      "security": [{ "auth_token": [] }],
      "requestBody": {
        "required": true,
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "type": "object",
              "properties": {
                "fullname": {
                  "type": "string"
                },
                "email": {
                  "type": "string"
                },
                "new_password": {
                  "type": "string",
                  "format": "password"
                },
                "confirm_new_password": {
                  "type": "string",
                  "format": "password"
                },
                "phone": {
                  "type": "string"
                }
              },
              "required": ["fullname", "email", "new_password", "confirm_new_password"]
            }
          }
        }
      },
      "responses": {
        "201": { "description": "Create new records" },
        "400": { "description": "Something went wrong" },
        "422": { "description": "Unprocessable Entity" },
        "500": { "description": "Internal Server Error" }
      }
    }
  },
  "/v1/auth/sign-in": {
    "post": {
      "tags": ["Auth"],
      "summary": "Login User",
      "security": [{ "auth_token": [] }],
      "requestBody": {
        "required": true,
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "type": "object",
              "properties": {
                "email": {
                  "type": "string",
                  "example": "user@example.com"
                },
                "password": {
                  "type": "string",
                  "format": "password",
                  "example": "password123"
                },
                "latitude": {
                  "type": "string",
                  "example": "-6.2088",
                  "description": "User latitude coordinate"
                },
                "longitude": {
                  "type": "string",
                  "example": "106.8456",
                  "description": "User longitude coordinate"
                },
                "turnstileToken": {
                  "type": "string",
                  "description": "Cloudflare Turnstile CAPTCHA token (required if TURNSTILE_ENABLED=true)",
                  "example": "0.abcdefghijklmnopqrstuvwxyz..."
                }
              },
              "required": ["email", "password"]
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Login successfully",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "success": { "type": "boolean", "example": true },
                  "message": { "type": "string", "example": "Login successfully" },
                  "data": {
                    "type": "object",
                    "properties": {
                      "access_token": { "type": "string" },
                      "expires_in": { "type": "number" },
                      "user": { "type": "object" }
                    }
                  }
                }
              }
            }
          }
        },
        "400": {
          "description": "Bad Request - Invalid credentials or CAPTCHA verification failed",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "success": { "type": "boolean", "example": false },
                  "message": {
                    "type": "string",
                    "example": "Verifikasi CAPTCHA gagal. Silakan coba lagi."
                  }
                }
              }
            }
          }
        },
        "422": { "description": "Unprocessable Entity" },
        "500": { "description": "Internal Server Error" }
      }
    }
  },
  "/v1/auth/verify-session": {
    "get": {
      "tags": ["Auth"],
      "summary": "Verify User Session",
      "security": [{ "auth_token": [] }],
      "responses": {
        "200": { "description": "Verify session successfully" },
        "400": { "description": "Something went wrong" },
        "422": { "description": "Unprocessable Entity" },
        "500": { "description": "Internal Server Error" }
      }
    }
  },
  "/v1/auth/sign-out": {
    "post": {
      "tags": ["Auth"],
      "summary": "Logout User",
      "security": [{ "auth_token": [] }],
      "requestBody": {
        "required": true,
        "content": {
          "application/x-www-form-urlencoded": {
            "schema": {
              "type": "object",
              "properties": {
                "user_id": {
                  "type": "string"
                }
              },
              "required": ["user_id"]
            }
          }
        }
      },
      "responses": {
        "200": { "description": "Logout successfully" },
        "400": { "description": "Something went wrong" },
        "422": { "description": "Unprocessable Entity" },
        "500": { "description": "Internal Server Error" }
      }
    }
  }
}
